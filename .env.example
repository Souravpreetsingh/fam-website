# ═══════════════════════════════════════════════════════════════
#  Flamingo aur Maina — Environment Variables
# ═══════════════════════════════════════════════════════════════

# ── Frontend (Vite) ──────────────────────────────────────────────
# Backend API base URL (used by the React app in src/)
# Defaults to "/api/v1" (same-origin via Netlify proxy).
# Set to your local or deployed backend URL.
VITE_API_URL=/api/v1

# ── Backend (Express) ──────────────────────────────────────────
# See backend/.env.example for a full list of backend variables.
# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/fam?retryWrites=true&w=majority

# JWT
JWT_ACCESS_SECRET=your-access-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Razorpay (payments)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# SMTP / Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=Flamingo aur Maina <noreply@flamingoaurmaina.com>

# Frontend URL (for CORS, email links, redirects)
FRONTEND_URL=http://localhost:5173
