# ═══════════════════════════════════════════════════════════════
#  Flamingo aur Maina — Environment Variables
#  Copy this file to .env and fill in your values.
#  For production, set these in the Netlify dashboard:
#    Site Settings → Environment variables
# ═══════════════════════════════════════════════════════════════

# ── Frontend (Vite) ──────────────────────────────────────────────
# Backend API base URL. Defaults to "/api/v1" (same-origin proxy
# via Netlify Function). Set to an external URL if needed.
VITE_API_URL=/api/v1

# ── Backend (Netlify Function) ──────────────────────────────────
# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/fam

# JWT secrets
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars

# CORS origin for the frontend
FRONTEND_URL=https://flamingoaurmaina.netlify.app

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Razorpay (payments)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret

# SMTP / Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
EMAIL_FROM=Flamingo aur Maina <noreply@yourdomain.com>
